# Database
DATABASE_URL=postgres://bg_tracker:bg_tracker_dev@localhost:5432/bg_tracker

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-key-change-in-production

# Server
HOST=127.0.0.1
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173
FRONTEND_HOST=0.0.0.0

# Geocoding (optional — falls back to Nominatim if empty)
GOOGLE_MAPS_API_KEY=

# Receipt OCR
ENABLE_RECEIPT_OCR=1
RECEIPT_OCR_PORT=8001
OCR_SERVICE_URL=http://localhost:8001
OCR_VL_ENABLED=0
OCR_HTTP_WORKERS=1
OCR_PARSE_CONCURRENCY_PER_WORKER=1
