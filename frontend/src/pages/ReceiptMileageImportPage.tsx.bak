// ----- Map Helpers -----

function FitBounds({ bounds }: { bounds: [number, number][] }) {
  const map = useMap()
  const prevKeyRef = useRef("")
  useEffect(() => {
    const key = bounds.map(([a, b]) => `${a.toFixed(5)},${b.toFixed(5)}`).join("|")
    if (key === prevKeyRef.current) return
    prevKeyRef.current = key
    if (bounds.length > 1) {
      map.fitBounds(L.latLngBounds(bounds), { padding: [20, 20] })
    } else if (bounds.length === 1) {
      map.setView(bounds[0], 13)
    }
  }, [map, bounds])
  return null
}

class MapErrorBoundary extends Component<{ children: ReactNode }, { error: string | null }> {
  state = { error: null as string | null }
  static getDerivedStateFromError(error: Error) {
    return { error: error.message }
  }
  componentDidCatch(error: Error, info: ErrorInfo) {
    console.error("Map render error:", error, info)
  }
  render() {
    if (this.state.error) {
      return <div className="text-xs text-red-600 py-2">Map failed to render: {this.state.error}</div>
    }
    return this.props.children
  }
}

const CLASSIFICATION_COLORS: Record<string, string> = {
  business: "#15803d",
  personal: "#1d4ed8",
}

const routeCache = new Map<string, { distance: number; coords: [number, number][] }>()

// ----- Segment Types -----

interface SegmentDraft {
  from_id: string
  to_id: string
  distance_km: string
  computed_km: string
  classification: string
  routeCoords: [number, number][]
  computing: boolean
  routeError: string | null
  source: string // "manual" | "timeline" | "receipt"
  waypoints: [number, number][] // resolved intermediate coords for Directions API
  // Detour mode: compute extra km from inserting business stops into a baseline route
  isDetour: boolean
  detourStopIds: string[]  // ordered business stop location IDs (waypoints)
  directKm: number | null  // baseline route distance (from → to, no stops)
  withStopsKm: number | null // route with business stops as waypoints
  timelineTotalKm: number | null // actual GPS-measured km from timeline (when available)
  directRouteCoords: [number, number][]
  withStopsRouteCoords: [number, number][]
  computingDirect: boolean
  computingWithStops: boolean
}

function emptySegment(): SegmentDraft {
  return {
    from_id: "",
    to_id: "",
    distance_km: "",
    computed_km: "",
    classification: "business",
    routeCoords: [],
    computing: false,
    routeError: null,
    source: "manual",
    waypoints: [],
    isDetour: false,
    detourStopIds: [],
    directKm: null,
    withStopsKm: null,
    timelineTotalKm: null,
    directRouteCoords: [],
    withStopsRouteCoords: [],
    computingDirect: false,
    computingWithStops: false,
  }
}

/** Format a UTC timestamp to local HH:MM */
function fmtTime(ts: string | null | undefined): string {
  if (!ts) return ""
  return new Date(ts).toLocaleTimeString("en-CA", { hour: "2-digit", minute: "2-digit", hour12: false })
}

/** Format a YYYY-MM-DD date with the day of week, e.g. "2025-11-17 (Monday)" */
function fmtDateWithDay(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00") // noon to avoid TZ shifts
  const day = d.toLocaleDateString("en-CA", { weekday: "long" })
  return `${dateStr} (${day})`
}

/** Number "Unknown" labels and infer missing drive endpoints from adjacent visits */
function labelTimelineSegments(segs: TravelSegment[]): Map<string, string> {
  const labels = new Map<string, string>()
  let unknownCounter = 0

  // Build a quick lookup: index → visit label (for inferring drive endpoints)
  const visitLabelAt = (idx: number, direction: "before" | "after"): string => {
    const step = direction === "before" ? -1 : 1
    for (let j = idx + step; j >= 0 && j < segs.length; j += step) {
      if (segs[j].segment_type === "visit") {
        return segs[j].visit_location_label || segs[j].from_location || ""
      }
    }
    return ""
  }

  for (let i = 0; i < segs.length; i++) {
    const s = segs[i]
    if (labels.has(s.id)) continue

    let rawLabel: string
    if (s.segment_type === "visit") {
      rawLabel = s.visit_location_label || s.from_location || ""
    } else {
      // Drive: use from_location, or infer from the previous visit
      rawLabel = s.from_location || visitLabelAt(i, "before")
    }

    if (!rawLabel || rawLabel.startsWith("Unknown") || rawLabel === "?") {
      unknownCounter++
      labels.set(s.id, `Unknown (${unknownCounter})`)
    } else {
      labels.set(s.id, rawLabel)
    }

    // Also label "to" for drives
    if (s.segment_type === "drive") {
      let toLabel = s.to_location || visitLabelAt(i, "after")
      if (!toLabel || toLabel.startsWith("Unknown") || toLabel === "?") {
        unknownCounter++
        labels.set(s.id + "_to", `Unknown (${unknownCounter})`)
      } else {
        labels.set(s.id + "_to", toLabel)
      }
    }
  }
  return labels
}

// ----- Route helper (backend proxy → Google Maps Directions) -----

async function fetchRoute(
  fromLat: number, fromLng: number, toLat: number, toLng: number,
  waypoints?: [number, number][],
): Promise<{ distance: number; coords: [number, number][] }> {
  const wpKey = waypoints?.map(([a, b]) => `${a},${b}`).join(";") || ""
  const key = `${fromLat},${fromLng}-${toLat},${toLng}|${wpKey}`
  if (routeCache.has(key)) return routeCache.get(key)!

  const data = await travel.directions(fromLat, fromLng, toLat, toLng, waypoints)
  const result = { distance: data.distance_meters, coords: data.coords.map(([lat, lng]) => [lat, lng] as [number, number]) }
  routeCache.set(key, result)
  return result
}

// ----- Route Map Component -----

const TIMELINE_COLORS: Record<string, { line: string; marker: string }> = {
  business: { line: "#16a34a", marker: "#15803d" },
  personal: { line: "#93c5fd", marker: "#60a5fa" },
}

function RouteMap({
  segments,
  locations,
  receiptLocations,
  timelineSegments,
  onTimelineDriveClick,
  hoveredSegmentId,
  onHoverSegment,
}: {
  segments: SegmentDraft[]
  locations: TravelLocation[]
  receiptLocations: ReceiptWithVendor[]
  timelineSegments?: TravelSegment[]
  onTimelineDriveClick?: (seg: TravelSegment) => void
  hoveredSegmentId?: string | null
  onHoverSegment?: (id: string | null) => void
}) {
  const [snappedRoutes, setSnappedRoutes] = useState<Map<string, [number, number][]>>(new Map())

  // Build all data structures via useMemo so hooks are called unconditionally
  const { allPoints, drives, timelineDriveData, timelineVisitData, receiptMarkers } = useMemo(() => {
    const pts: [number, number][] = []

    // Manual segment routes (solid lines)
    const drvs: { positions: [number, number][]; color: string; label: string; isDetour: boolean }[] = []
    for (const seg of segments) {
      const fromLoc = locations.find((l) => l.id === seg.from_id)
    const toLoc = locations.find((l) => l.id === seg.to_id)
    if (!fromLoc?.latitude || !fromLoc?.longitude || !toLoc?.latitude || !toLoc?.longitude) continue
    const start: [number, number] = [fromLoc.latitude, fromLoc.longitude]
    const end: [number, number] = [toLoc.latitude, toLoc.longitude]
    pts.push(start, end)
    const positions = seg.routeCoords.length > 0 ? seg.routeCoords : [start, end]
    drvs.push({
      positions,
      color: CLASSIFICATION_COLORS[seg.classification] || "#6b7280",
      label: `${fromLoc.label} \u2192 ${toLoc.label} (${seg.distance_km || seg.computed_km || "?"} km)`,
      isDetour: seg.isDetour,
    })
  }

  // Build indexed labels for unknowns
  const tlLabels = timelineSegments ? labelTimelineSegments(timelineSegments) : new Map<string, string>()

  // Timeline drives (dashed lines) + visit markers
  // Timeline drives + visits
  const tlDrives: {
    key: string; start: [number, number]; end: [number, number]
    color: string; label: string; timeRange: string; seg: TravelSegment
  }[] = []
  const tlVisits: {
    pos: [number, number]; label: string; classification: string
    duration?: number; timeRange: string; segId: string
  }[] = []

  if (timelineSegments) {
    for (const ts of timelineSegments) {
      const timeRange = `${fmtTime(ts.start_time)}\u2013${fmtTime(ts.end_time)}`
      if (ts.segment_type === "drive" && ts.start_lat != null && ts.start_lng != null && ts.end_lat != null && ts.end_lng != null) {
        const start: [number, number] = [ts.start_lat, ts.start_lng]
        const end: [number, number] = [ts.end_lat, ts.end_lng]
        pts.push(start, end)
        const km = ts.distance_meters != null ? (ts.distance_meters / 1000).toFixed(1) : "?"
        const fromLabel = tlLabels.get(ts.id) || ts.from_location || "?"
        const toLabel = tlLabels.get(ts.id + "_to") || ts.to_location || "?"
        const key = `${ts.start_lat},${ts.start_lng}-${ts.end_lat},${ts.end_lng}`
        tlDrives.push({
          key, start, end,
          color: TIMELINE_COLORS[ts.classification]?.line || "#9ca3af",
          label: `${fromLabel} \u2192 ${toLabel} (${km} km)`,
          timeRange, seg: ts,
        })
      } else if (ts.segment_type === "visit" && ts.start_lat != null && ts.start_lng != null) {
        const pos: [number, number] = [ts.start_lat, ts.start_lng]
        pts.push(pos)
        tlVisits.push({
          pos,
          label: tlLabels.get(ts.id) || ts.visit_location_label || ts.from_location || "Unknown",
          classification: ts.classification,
          duration: ts.visit_duration_minutes ?? undefined,
          timeRange,
          segId: ts.id,
        })
      }
    }
  }

  // Receipt store markers
  const rcptMarkers = receiptLocations
    .filter((r) => r.store_location_id != null && r.store_latitude != null && r.store_longitude != null)
    .map((r) => ({
      pos: [r.store_latitude!, r.store_longitude!] as [number, number],
      label: `${r.vendor_name} ($${parseFloat(r.total).toFixed(2)})`,
      address: r.store_label || r.store_address,
    }))
  for (const rm of rcptMarkers) pts.push(rm.pos)

  return { allPoints: pts, drives: drvs, timelineDriveData: tlDrives, timelineVisitData: tlVisits, receiptMarkers: rcptMarkers }
  }, [segments, locations, receiptLocations, timelineSegments])

  // Road-snap timeline drives via Directions API
  const driveKeys = useMemo(() => timelineDriveData.map((d) => d.key).join(","), [timelineDriveData])
  useEffect(() => {
    if (timelineDriveData.length === 0) return
    let cancelled = false
    const snap = async () => {
      const newRoutes = new Map<string, [number, number][]>()
      for (const d of timelineDriveData) {
        if (cancelled) break
        if (timelineRouteCache.has(d.key)) {
          newRoutes.set(d.key, timelineRouteCache.get(d.key)!)
          continue
        }
        try {
          const data = await travel.directions(d.start[0], d.start[1], d.end[0], d.end[1])
          const coords: [number, number][] = data.coords.map(([lat, lng]) => [lat, lng] as [number, number])
          newRoutes.set(d.key, coords)
          timelineRouteCache.set(d.key, coords)
        } catch {
          // Fall back to straight line
        }
      }
      if (!cancelled) setSnappedRoutes(newRoutes)
    }
    snap()
    return () => { cancelled = true }
  }, [driveKeys])

  if (allPoints.length === 0) {
    return <div className="text-xs text-muted-foreground italic py-2">No geocoded locations or timeline data to display.</div>
  }

  // De-dup visit markers by rounding position
  const seenVisitKeys = new Set<string>()
  const dedupedVisits = timelineVisitData.filter((v) => {
    const key = `${v.pos[0].toFixed(4)},${v.pos[1].toFixed(4)}`
    if (seenVisitKeys.has(key)) return false
    seenVisitKeys.add(key)
    return true
  })

  return (
    <MapErrorBoundary>
      <div className="h-80 w-full rounded border overflow-hidden relative z-0">
        <MapContainer center={allPoints[0]} zoom={10} className="h-full w-full" scrollWheelZoom={false}>
          <GoogleTileLayer />
          <FitBounds bounds={allPoints} />

          {/* Timeline drives — road-snapped, clickable */}
          {timelineDriveData.map((d, i) => {
            const isHovered = hoveredSegmentId === d.seg.id
            const positions = snappedRoutes.get(d.key) || [d.start, d.end]
            return (
              <Polyline
                key={`tl-drive-${i}`}
                positions={positions}
                color={isHovered ? "#f59e0b" : d.color}
                weight={isHovered ? 5 : 4}
                opacity={isHovered ? 1 : 0.85}
                eventHandlers={{
                  click: onTimelineDriveClick ? () => onTimelineDriveClick(d.seg) : undefined,
                  mouseover: onHoverSegment ? () => onHoverSegment(d.seg.id) : undefined,
                  mouseout: onHoverSegment ? () => onHoverSegment(null) : undefined,
                }}
              >
                <Tooltip>
                  <div>
                    <div>{d.label}</div>
                    <div className="text-xs text-gray-400">{d.timeRange}</div>
                    <div className="text-xs text-gray-500">Click to add as segment</div>
                  </div>
                </Tooltip>
              </Polyline>
            )
          })}

          {/* Timeline visit markers — small dots */}
          {dedupedVisits.map((v, i) => {
            const isHovered = hoveredSegmentId === v.segId
            return (
              <CircleMarker
                key={`tl-visit-${i}`}
                center={v.pos}
                radius={isHovered ? 8 : 5}
                fillColor={isHovered ? "#f59e0b" : (TIMELINE_COLORS[v.classification]?.marker || "#9ca3af")}
                fillOpacity={isHovered ? 1 : 0.7}
                color={isHovered ? "#d97706" : "#fff"}
                weight={isHovered ? 2 : 1}
                eventHandlers={{
                  mouseover: onHoverSegment ? () => onHoverSegment(v.segId) : undefined,
                  mouseout: onHoverSegment ? () => onHoverSegment(null) : undefined,
                }}
              >
                <Tooltip>
                  <div>
                    <strong>{v.label}</strong>
                    <div className="text-xs text-gray-400">{v.timeRange}</div>
                    {v.duration != null && <div className="text-xs">{v.duration} min</div>}
                    <div className="text-xs text-gray-500">{v.classification}</div>
                  </div>
                </Tooltip>
              </CircleMarker>
            )
          })}

          {/* Manual segment routes — solid lines (skip detour segments when timeline drives are shown) */}
          {drives.filter((d) => !(d.isDetour && timelineDriveData.length > 0)).map((d, i) => (
            <Polyline key={`drive-${i}`} positions={d.positions} color={d.color} weight={4} opacity={0.9}>
              <Tooltip>{d.label}</Tooltip>
            </Polyline>
          ))}

          {/* Receipt store markers — bold red */}
          {receiptMarkers.map((r, i) => (
            <CircleMarker key={`rcpt-${i}`} center={r.pos} radius={8} fillColor="#e11d48" fillOpacity={0.9} color="#fff" weight={2}>
              <Tooltip>
                <div>
                  <strong>{r.label}</strong>
                  {r.address && <div className="text-xs">{r.address}</div>}
                </div>
              </Tooltip>
            </CircleMarker>
          ))}
        </MapContainer>

        {/* Legend */}
        {timelineSegments && timelineSegments.length > 0 && (
          <div className="absolute bottom-2 right-2 z-[1000] bg-white/90 border rounded px-2 py-1 text-[10px] space-y-0.5">
            <div className="flex items-center gap-1.5">
              <span className="inline-block w-4 border-t-2" style={{ borderColor: "#93c5fd" }} />
              <span>Timeline (personal)</span>
            </div>
            <div className="flex items-center gap-1.5">
              <span className="inline-block w-4 border-t-2" style={{ borderColor: "#16a34a" }} />
              <span>Timeline (business)</span>
            </div>
            <div className="flex items-center gap-1.5">
              <span className="inline-block w-4 border-t-2" style={{ borderColor: "#15803d" }} />
              <span>Manual segment</span>
            </div>
            <div className="flex items-center gap-1.5">
              <span className="inline-block w-2.5 h-2.5 rounded-full bg-[#e11d48]" />
              <span>Receipt store</span>
            </div>
          </div>
        )}
      </div>
    </MapErrorBoundary>
  )
}

// ----- Smart segment builder from timeline data -----

/**
 * Smart segment builder using timeline + receipt data.
 *
 * Strategy: find spans between personal locations that contain business store
 * visits. Each such span becomes a detour segment — the personal trip is the
 * baseline, and the stores visited along the way are detour waypoints.
 *
 * Store ordering: uses timeline visit order when available (high confidence),
 * falls back to closest-to-furthest from the start location.
 */
function buildSegmentsFromTimeline(
  timelineSegs: TravelSegment[],
  storeLocations: TravelLocation[],
  allLocations: TravelLocation[],
): SegmentDraft[] {
  const storeLabels = new Set(storeLocations.map((l) => l.label.toLowerCase()))
  const locByLabel = new Map(allLocations.map((l) => [l.label.toLowerCase(), l]))

  // Step 1: Extract ordered resolvable visits from timeline
  const timelineVisits: { index: number; label: string; loc: TravelLocation; isStore: boolean }[] = []
  for (let i = 0; i < timelineSegs.length; i++) {
    const ts = timelineSegs[i]
    if (ts.segment_type !== "visit") continue
    const label = (ts.visit_location_label || ts.from_location || "").toLowerCase()
    const loc = locByLabel.get(label)
    if (!loc) continue
    timelineVisits.push({ index: i, label, loc, isStore: storeLabels.has(label) })
  }

  // Step 2: Find confirmed store visits (appear in both timeline and receipts)
  const confirmedStoreVisits = timelineVisits.filter((v) => v.isStore)
  if (confirmedStoreVisits.length === 0) return []

  // Step 3: Find personal locations bracketing the store visits
  // Look for the last personal location before the first store, and the first personal after the last store
  const firstStoreIdx = timelineVisits.findIndex((v) => v === confirmedStoreVisits[0])
  const lastStoreIdx = timelineVisits.findIndex((v) => v === confirmedStoreVisits[confirmedStoreVisits.length - 1])

  // Find departure: last personal visit before stores
  let departureVisit = null
  for (let i = firstStoreIdx - 1; i >= 0; i--) {
    if (timelineVisits[i].loc.location_type === "personal") {
      departureVisit = timelineVisits[i]
      break
    }
  }

  // Find return: first personal visit after stores
  let returnVisit = null
  for (let i = lastStoreIdx + 1; i < timelineVisits.length; i++) {
    if (timelineVisits[i].loc.location_type === "personal") {
      returnVisit = timelineVisits[i]
      break
    }
  }

  // Need at least one personal endpoint to create a detour
  if (!departureVisit && !returnVisit) return []

  const startLoc = departureVisit?.loc
  const endLoc = returnVisit?.loc

  // If we only have one side, use it for both (round trip from/to same location)
  const fromId = startLoc?.id || endLoc!.id
  const toId = endLoc?.id || startLoc!.id

  // Step 4: Order the store stops (waypoints for the detour)
  // Use timeline chronological order — stores appear in the order the timeline visited them
  const orderedStoreIds: string[] = []
  const seenStores = new Set<string>()
  for (const v of confirmedStoreVisits) {
    if (!seenStores.has(v.loc.id)) {
      seenStores.add(v.loc.id)
      orderedStoreIds.push(v.loc.id)
    }
  }

  // If no timeline order was available, fall back to closest-to-furthest from start
  if (orderedStoreIds.length === 0 && storeLocations.length > 0) {
    const refLoc = allLocations.find((l) => l.id === fromId)
    if (refLoc?.latitude && refLoc?.longitude) {
      const sorted = [...storeLocations]
        .filter((l) => l.latitude && l.longitude)
        .sort((a, b) => {
          const distA = Math.hypot((a.latitude! - refLoc.latitude!) * 111, (a.longitude! - refLoc.longitude!) * 85)
          const distB = Math.hypot((b.latitude! - refLoc.latitude!) * 111, (b.longitude! - refLoc.longitude!) * 85)
          return distA - distB
        })
      for (const loc of sorted) orderedStoreIds.push(loc.id)
    } else {
      for (const loc of storeLocations) orderedStoreIds.push(loc.id)
    }
  }

  // Step 5: Sum actual GPS-measured km from timeline drives between departure and return
  const startIdx = departureVisit ? departureVisit.index : 0
  const endIdx = returnVisit ? returnVisit.index : timelineSegs.length
  let timelineTotalMeters = 0
  let hasMissingDistance = false
  for (let i = startIdx; i < endIdx; i++) {
    const ts = timelineSegs[i]
    if (ts.segment_type === "drive") {
      if (ts.distance_meters != null) {
        timelineTotalMeters += ts.distance_meters
      } else {
        hasMissingDistance = true
      }
    }
  }
  const timelineTotalKm = !hasMissingDistance && timelineTotalMeters > 0
    ? timelineTotalMeters / 1000
    : null

  // Step 6: Build a single detour segment
  return [{
    ...emptySegment(),
    from_id: fromId,
    to_id: toId,
    classification: "business",
    source: "timeline",
    isDetour: true,
    detourStopIds: orderedStoreIds,
    timelineTotalKm,
  }]
}

// ----- Main Page -----

export default function ReceiptMileageImportPage() {
  const [fromDate, setFromDate] = useState("")
  const [toDate, setToDate] = useState("")
  const [selectedDate, setSelectedDate] = useState<string | null>(null)
  const [segments, setSegments] = useState<SegmentDraft[]>([emptySegment()])
  const [purpose, setPurpose] = useState("")
  const [notes, setNotes] = useState("")
  const [hoveredSegmentId, setHoveredSegmentId] = useState<string | null>(null)

  const { data: receipts, isLoading: receiptsLoading } = useReceipts()
  const { data: allLogs } = useTripLogs()
  const { data: travelLocations = [] } = useTravelLocations()
  const createReceiptTripLog = useCreateReceiptTripLog()
  const createTravelLocation = useCreateTravelLocation()
  const updateReceipt = useUpdateReceipt()
  const [pendingLocations, setPendingLocations] = useState<Record<string, string>>({})

  // Inline add-new-location state: { segIndex, field } identifies which segment picker triggered it
  const [newLocTarget, setNewLocTarget] = useState<{ segIndex: number; field: "from_id" | "to_id" } | null>(null)
  const [newLocLabel, setNewLocLabel] = useState("")
  const [newLocAddress, setNewLocAddress] = useState("")
  const [newLocType, setNewLocType] = useState("personal")
  const { data: timelineSegments } = useTravelSegmentsForDate(selectedDate)

  const onlineLocation = useMemo(
    () => travelLocations.find((l) => l.location_type === "online"),
    [travelLocations]
  )
  const logsByDate = useMemo(() => {
    const map = new Map<string, TravelTripLog>()
    if (allLogs) for (const log of allLogs) map.set(log.trip_date, log)
    return map
  }, [allLogs])

  const homeLocation = useMemo(
    () => travelLocations.find((l) => l.label.toLowerCase() === "home" && l.location_type === "personal"),
    [travelLocations]
  )

  // Non-excluded locations with coordinates, home first
  const locationOptions = useMemo(() => {
    const locs = travelLocations.filter((l) => !l.excluded && l.latitude != null && l.longitude != null)
    return locs.sort((a, b) => {
      if (a.id === homeLocation?.id) return -1
      if (b.id === homeLocation?.id) return 1
      return a.label.localeCompare(b.label)
    })
  }, [travelLocations, homeLocation])

  // Only in-store receipts (have a linked store location)
  const receiptsByDate = useMemo(() => {
    if (!receipts) return []
    const map = new Map<string, ReceiptWithVendor[]>()
    for (const r of receipts) {
      if (fromDate && r.receipt_date < fromDate) continue
      if (toDate && r.receipt_date > toDate) continue
      if (!r.store_location_id) continue
      if (r.store_location_id === onlineLocation?.id) continue
      const existing = map.get(r.receipt_date) || []
      existing.push(r)
      map.set(r.receipt_date, existing)
    }
    return Array.from(map.entries())
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([date, recs]) => ({
        date,
        receipts: recs,
        totalSpent: recs.reduce((sum, r) => sum + parseFloat(r.total), 0),
        vendors: [...new Set(recs.map((r) => r.vendor_name))],
        storeCount: new Set(recs.map((r) => r.store_location_id)).size,
        hasLog: logsByDate.has(date),
        log: logsByDate.get(date),
      }))
  }, [receipts, fromDate, toDate, logsByDate, onlineLocation])

  const selectedDateData = useMemo(
    () => receiptsByDate.find((d) => d.date === selectedDate),
    [receiptsByDate, selectedDate]
  )

  const receiptStoreLocationIds = useMemo(() => {
    if (!selectedDateData) return new Set<string>()
    const ids = new Set<string>()
    for (const r of selectedDateData.receipts) {
      if (r.store_location_id) ids.add(r.store_location_id)
    }
    return ids
  }, [selectedDateData])

  const [addingCustomStop, setAddingCustomStop] = useState<Set<number>>(new Set())

  // Receipts without a store location, grouped by date
  const unlinkedByDate = useMemo(() => {
    if (!receipts) return []
    const map = new Map<string, ReceiptWithVendor[]>()
    for (const r of receipts) {
      if (fromDate && r.receipt_date < fromDate) continue
      if (toDate && r.receipt_date > toDate) continue
      if (r.store_location_id) continue
      const existing = map.get(r.receipt_date) || []
      existing.push(r)
      map.set(r.receipt_date, existing)
    }
    return Array.from(map.entries())
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([date, recs]) => ({ date, receipts: recs }))
  }, [receipts, fromDate, toDate])

  // Find travel_location for receipt (direct FK lookup)
  const findMatchingLocation = useCallback(
    (receipt: ReceiptWithVendor): TravelLocation | undefined => {
      if (!receipt.store_location_id) return undefined
      return locationOptions.find((l) => l.id === receipt.store_location_id)
    },
    [locationOptions]
  )

  // Resolve a timeline location label to a travel_location by label match
  const resolveLocationByLabel = useCallback(
    (label: string | null): TravelLocation | undefined => {
      if (!label) return undefined
      return locationOptions.find(
        (l) => l.label.toLowerCase() === label.toLowerCase()
      )
    },
    [locationOptions]
  )

  // Add a timeline drive as a manual segment (called from map click)
  const handleTimelineDriveClick = useCallback(
    (ts: TravelSegment) => {
      const fromLoc = resolveLocationByLabel(ts.from_location)
      const toLoc = resolveLocationByLabel(ts.to_location)
      if (!fromLoc || !toLoc) return // can't resolve location labels

      const km = ts.distance_meters != null ? (ts.distance_meters / 1000).toFixed(1) : ""
      const newSeg: SegmentDraft = {
        ...emptySegment(),
        from_id: fromLoc.id,
        to_id: toLoc.id,
        distance_km: km,
        computed_km: km,
        classification: ts.classification === "business" ? "business" : "personal",
        source: "timeline",
      }

      setSegments((prev) => {
        // If there's only one empty segment, replace it
        if (prev.length === 1 && !prev[0].from_id && !prev[0].to_id) {
          return [newSeg]
        }
        // Don't add duplicates
        if (prev.some((s) => s.from_id === newSeg.from_id && s.to_id === newSeg.to_id)) {
          return prev
        }
        return [...prev, newSeg]
      })
    },
    [resolveLocationByLabel]
  )

  // Track which date we last auto-generated segments for
  const autoGenDateRef = useRef<string | null>(null)

  // Select a date — sets up purpose/notes but lets the effect handle segment generation
  const handleSelectDate = useCallback(
    (date: string) => {
      setSelectedDate(date)
      autoGenDateRef.current = null // allow auto-gen for new date
      const data = receiptsByDate.find((d) => d.date === date)
      if (!data) return

      setPurpose(`Business: ${data.vendors.join(", ")}`)
      setNotes("")
      setSegments([emptySegment()])
    },
    [receiptsByDate]
  )

  // Auto-generate segments when timeline data arrives for selected date
  useEffect(() => {
    if (!selectedDate) return
    if (autoGenDateRef.current === selectedDate) return // already generated
    if (!timelineSegments || timelineSegments.length === 0) return

    const data = receiptsByDate.find((d) => d.date === selectedDate)
    if (!data) return

    // Collect unique store locations from receipts
    const storeLocations: TravelLocation[] = []
    const storeLocIds = new Set<string>()
    for (const r of data.receipts) {
      const match = findMatchingLocation(r)
      if (match && !storeLocIds.has(match.id)) {
        storeLocIds.add(match.id)
        storeLocations.push(match)
      }
    }

    if (storeLocations.length === 0) {
      autoGenDateRef.current = selectedDate
      return
    }

    const tlSegments = buildSegmentsFromTimeline(timelineSegments, storeLocations, locationOptions)
    if (tlSegments.length > 0) {
      setSegments(tlSegments)
    }
    autoGenDateRef.current = selectedDate
  }, [selectedDate, timelineSegments, receiptsByDate, findMatchingLocation, locationOptions])

  // Compute distance for a single segment via Google Maps Directions
  const computeSegmentDistance = useCallback(
    async (index: number) => {
      setSegments((prev) => prev.map((s, i) => i === index ? { ...s, computing: true, routeError: null } : s))

      const seg = segments[index]
      const fromLoc = locationOptions.find((l) => l.id === seg.from_id)
      const toLoc = locationOptions.find((l) => l.id === seg.to_id)

      if (!fromLoc?.latitude || !fromLoc?.longitude || !toLoc?.latitude || !toLoc?.longitude) {
        setSegments((prev) => prev.map((s, i) => i === index ? { ...s, computing: false, routeError: "Location missing coordinates" } : s))
        return
      }

      try {
        const result = await fetchRoute(fromLoc.latitude, fromLoc.longitude, toLoc.latitude, toLoc.longitude, seg.waypoints.length > 0 ? seg.waypoints : undefined)
        setSegments((prev) =>
          prev.map((s, i) =>
            i === index
              ? {
                  ...s,
                  computing: false,
                  routeError: null,
                  computed_km: (result.distance / 1000).toFixed(1),
                  distance_km: s.distance_km || (result.distance / 1000).toFixed(1),
                  routeCoords: result.coords,
                }
              : s
          )
        )
      } catch (err) {
        const msg = err instanceof Error ? err.message : "Directions API failed"
        setSegments((prev) =>
          prev.map((s, i) =>
            i === index
              ? { ...s, computing: false, routeError: msg, computed_km: "", routeCoords: [] }
              : s
          )
        )
      }
    },
    [segments, locationOptions]
  )

  // Auto-compute distances when segments have both from/to set (non-detour only)
  useEffect(() => {
    for (let i = 0; i < segments.length; i++) {
      const seg = segments[i]
      if (seg.isDetour) continue // detour segments compute their own distances
      if (seg.from_id && seg.to_id && !seg.computed_km && !seg.computing) {
        computeSegmentDistance(i)
        break // one at a time to avoid rate limits
      }
    }
  }, [segments, computeSegmentDistance])

  // ----- Per-Segment Detour Route Computation -----
  // Compute DIRECT route (no stops) for each detour segment that needs it
  useEffect(() => {
    for (let i = 0; i < segments.length; i++) {
      const seg = segments[i]
      if (!seg.isDetour || !seg.from_id || !seg.to_id) continue
      if (seg.directKm != null || seg.computingDirect) continue // already done or in progress
      const fromLoc = locationOptions.find((l) => l.id === seg.from_id)
      const toLoc = locationOptions.find((l) => l.id === seg.to_id)
      if (!fromLoc?.latitude || !fromLoc?.longitude || !toLoc?.latitude || !toLoc?.longitude) continue

      setSegments((prev) => prev.map((s, j) => j === i ? { ...s, computingDirect: true } : s))
      fetchRoute(fromLoc.latitude, fromLoc.longitude, toLoc.latitude, toLoc.longitude)
        .then((result) => {
          setSegments((prev) => prev.map((s, j) => j === i ? {
            ...s,
            directKm: result.distance / 1000,
            directRouteCoords: result.coords,
            computingDirect: false,
          } : s))
        })
        .catch(() => {
          setSegments((prev) => prev.map((s, j) => j === i ? { ...s, computingDirect: false } : s))
        })
      break // one at a time
    }
  }, [segments, locationOptions])

  // Compute route WITH STOPS for each detour segment that needs it
  // When timeline GPS data is available, use it directly instead of Directions API
  useEffect(() => {
    for (let i = 0; i < segments.length; i++) {
      const seg = segments[i]
      if (!seg.isDetour || !seg.from_id || !seg.to_id || seg.detourStopIds.length === 0) continue
      if (seg.withStopsKm != null || seg.computingWithStops) continue

      const fromLoc = locationOptions.find((l) => l.id === seg.from_id)
      const toLoc = locationOptions.find((l) => l.id === seg.to_id)
      if (!fromLoc?.latitude || !fromLoc?.longitude || !toLoc?.latitude || !toLoc?.longitude) continue

      const waypoints: [number, number][] = []
      for (const stopId of seg.detourStopIds) {
        const loc = locationOptions.find((l) => l.id === stopId)
        if (loc?.latitude && loc?.longitude) waypoints.push([loc.latitude, loc.longitude])
      }
      if (waypoints.length === 0) continue

      // Always call Directions API for route coords (map rendering)
      // but use GPS-measured distance when available from timeline
      const useTimelineKm = seg.timelineTotalKm != null

      setSegments((prev) => prev.map((s, j) => j === i ? { ...s, computingWithStops: true } : s))
      fetchRoute(fromLoc.latitude, fromLoc.longitude, toLoc.latitude, toLoc.longitude, waypoints)
        .then((result) => {
          setSegments((prev) => prev.map((s, j) => {
            if (j !== i) return s
            const withStopsKm = useTimelineKm && s.timelineTotalKm != null
              ? s.timelineTotalKm
              : result.distance / 1000
            const detour = s.directKm != null ? Math.max(0, withStopsKm - s.directKm) : 0
            return {
              ...s,
              withStopsKm,
              withStopsRouteCoords: result.coords,
              computingWithStops: false,
              distance_km: detour.toFixed(1),
              computed_km: detour.toFixed(1),
              routeCoords: result.coords,
            }
          }))
        })
        .catch(() => {
          // If Directions API fails but we have timeline km, still use it for distance
          if (useTimelineKm) {
            setSegments((prev) => prev.map((s, j) => {
              if (j !== i) return s
              const withStopsKm = s.timelineTotalKm!
              const detour = s.directKm != null ? Math.max(0, withStopsKm - s.directKm) : 0
              return {
                ...s,
                withStopsKm,
                computingWithStops: false,
                distance_km: detour.toFixed(1),
                computed_km: detour.toFixed(1),
              }
            }))
          } else {
            setSegments((prev) => prev.map((s, j) => j === i ? { ...s, computingWithStops: false } : s))
          }
        })
      break // one at a time
    }
  }, [segments, locationOptions])

  const addSegment = () => setSegments((prev) => [...prev, emptySegment()])

  const removeSegment = (index: number) => {
    setSegments((prev) => (prev.length > 1 ? prev.filter((_, i) => i !== index) : prev))
  }

  const updateSegment = (index: number, field: keyof SegmentDraft, value: string) => {
    setSegments((prev) =>
      prev.map((s, i) => {
        if (i !== index) return s
        const updated = { ...s, [field]: value }
        if (field === "from_id" || field === "to_id") {
          updated.computed_km = ""
          updated.distance_km = ""
          updated.routeCoords = []
          updated.routeError = null
          // Reset detour computations when endpoints change
          if (updated.isDetour) {
            updated.directKm = null
            updated.withStopsKm = null
            updated.timelineTotalKm = null // GPS total no longer valid for new endpoints
            updated.directRouteCoords = []
            updated.withStopsRouteCoords = []
          }
        }
        return updated
      })
    )
  }

  // Toggle detour mode for a segment
  const toggleDetour = (index: number) => {
    setSegments((prev) => prev.map((s, i) => {
      if (i !== index) return s
      const toggled = !s.isDetour
      if (toggled) {
        // When enabling detour, auto-populate stops from receipt store locations
        const data = receiptsByDate.find((d) => d.date === selectedDate)
        const stopIds: string[] = []
        const seen = new Set<string>()
        if (data) {
          for (const r of data.receipts) {
            const match = findMatchingLocation(r)
            if (match && !seen.has(match.id)) {
              seen.add(match.id)
              stopIds.push(match.id)
            }
          }
        }
        return {
          ...s,
          isDetour: true,
          detourStopIds: stopIds,
          classification: "business",
          directKm: null,
          withStopsKm: null,
          directRouteCoords: [],
          withStopsRouteCoords: [],
          // Clear standard route computation
          computed_km: "",
          distance_km: "",
          routeCoords: [],
        }
      }
      return {
        ...s,
        isDetour: false,
        detourStopIds: [],
        directKm: null,
        withStopsKm: null,
        directRouteCoords: [],
        withStopsRouteCoords: [],
        computed_km: "",
        distance_km: "",
        routeCoords: [],
      }
    }))
  }

  // Add/remove a stop from a detour segment
  const addDetourStop = (segIndex: number, locationId: string) => {
    setSegments((prev) => prev.map((s, i) => {
      if (i !== segIndex || s.detourStopIds.includes(locationId)) return s
      return { ...s, detourStopIds: [...s.detourStopIds, locationId], withStopsKm: null, withStopsRouteCoords: [], computed_km: "", distance_km: "" }
    }))
  }

  const removeDetourStop = (segIndex: number, stopIndex: number) => {
    setSegments((prev) => prev.map((s, i) => {
      if (i !== segIndex) return s
      return { ...s, detourStopIds: s.detourStopIds.filter((_, j) => j !== stopIndex), withStopsKm: null, withStopsRouteCoords: [], computed_km: "", distance_km: "" }
    }))
  }

  const moveDetourStop = (segIndex: number, stopIndex: number, direction: "up" | "down") => {
    setSegments((prev) => prev.map((s, i) => {
      if (i !== segIndex) return s
      const stops = [...s.detourStopIds]
      const newIdx = direction === "up" ? stopIndex - 1 : stopIndex + 1
      if (newIdx < 0 || newIdx >= stops.length) return s
      ;[stops[stopIndex], stops[newIdx]] = [stops[newIdx], stops[stopIndex]]
      return { ...s, detourStopIds: stops, withStopsKm: null, withStopsRouteCoords: [], computed_km: "", distance_km: "" }
    }))
  }

  const canSave = segments.some((s) => s.from_id && s.to_id && parseFloat(s.distance_km) > 0)

  const handleSave = () => {
    if (!selectedDate || !canSave) return
    const validSegments = segments
      .filter((s) => s.from_id && s.to_id && parseFloat(s.distance_km) > 0)
      .map((s) => {
        const fromLoc = locationOptions.find((l) => l.id === s.from_id)
        const toLoc = locationOptions.find((l) => l.id === s.to_id)
        if (s.isDetour) {
          const stopLabels = s.detourStopIds
            .map((id) => locationOptions.find((l) => l.id === id)?.label || "")
            .filter(Boolean)
          return {
            from_location: fromLoc?.label || "",
            to_location: `${toLoc?.label || ""} via ${stopLabels.join(", ")}`,
            distance_km: parseFloat(s.distance_km),
            classification: "business",
          }
        }
        return {
          from_location: fromLoc?.label || "",
          to_location: toLoc?.label || "",
          distance_km: parseFloat(s.distance_km),
          classification: s.classification,
        }
      })

    createReceiptTripLog.mutate(
      {
        trip_date: selectedDate,
        purpose: purpose || undefined,
        notes: notes || undefined,
        segments: validSegments,
      },
      {
        onSuccess: () => {
          setSelectedDate(null)
          setSegments([emptySegment()])
          setPurpose("")
          setNotes("")
        },
      }
    )
  }

  if (receiptsLoading) {
    return <div className="p-8 text-muted-foreground">Loading...</div>
  }

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <h1 className="text-2xl font-bold">Receipt Mileage Import</h1>
      </div>

      {/* Date Filters */}
      <div className="flex items-center gap-4">
        <div className="flex items-center gap-2">
          <label className="text-sm font-medium">From:</label>
          <DateInput value={fromDate} onChange={setFromDate} className="w-36" />
        </div>
        <div className="flex items-center gap-2">
          <label className="text-sm font-medium">To:</label>
          <DateInput value={toDate} onChange={setToDate} className="w-36" />
        </div>
        {(fromDate || toDate) && (
          <Button variant="ghost" size="sm" onClick={() => { setFromDate(""); setToDate("") }}>
            Clear
          </Button>
        )}
        <span className="text-xs text-muted-foreground ml-auto">
          Showing in-store receipts only. Online orders are excluded.
        </span>
      </div>

      {/* Unlinked Receipts */}
      {unlinkedByDate.length > 0 && (
        <Card>
          <CardHeader className="py-3">
            <CardTitle className="text-sm flex items-center gap-2">
              <AlertTriangle className="h-4 w-4 text-amber-500" />
              Receipts Without Store Location ({unlinkedByDate.reduce((n, g) => n + g.receipts.length, 0)})
            </CardTitle>
          </CardHeader>
          <CardContent className="pt-0">
            <div className="space-y-3">
              {unlinkedByDate.map(({ date, receipts: recs }) => (
                <div key={date}>
                  <div className="text-xs font-medium text-muted-foreground mb-1">{date}</div>
                  <div className="space-y-1">
                    {recs.map((r) => (
                      <div key={r.id} className="flex items-center gap-2 bg-slate-50 border rounded px-3 py-1.5 text-xs">
                        <Link to={`/receipts/${r.id}`} className="font-medium min-w-[120px] text-blue-600 hover:underline">{r.vendor_name}</Link>
                        <span className="text-muted-foreground w-16">${parseFloat(r.total).toFixed(2)}</span>
                        <LocationSearch
                          locations={locationOptions}
                          value={pendingLocations[r.id] || ""}
                          onValueChange={(val) => setPendingLocations((prev) => ({ ...prev, [r.id]: val }))}
                          placeholder="Search locations..."
                          className="flex-1"
                          triggerClassName="h-7"
                        />
                        <Button
                          variant="outline"
                          size="sm"
                          className="h-7 text-xs"
                          disabled={!pendingLocations[r.id] || updateReceipt.isPending}
                          onClick={() => {
                            updateReceipt.mutate(
                              { id: r.id, store_location_id: pendingLocations[r.id] },
                              {
                                onSuccess: () => {
                                  setPendingLocations((prev) => {
                                    const next = { ...prev }
                                    delete next[r.id]
                                    return next
                                  })
                                },
                              }
                            )
                          }}
                        >
                          <Save className="h-3 w-3" />
                        </Button>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      )}

      <div className="grid grid-cols-5 gap-6">
        {/* Left: Receipt dates (2 cols) */}
        <Card className="col-span-2">
          <CardHeader>
            <CardTitle className="text-sm">Receipt Dates ({receiptsByDate.length})</CardTitle>
          </CardHeader>
          <CardContent className="p-0">
            {receiptsByDate.length > 0 ? (
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Date</TableHead>
                    <TableHead>Vendors</TableHead>
                    <TableHead className="text-right">Spent</TableHead>
                    <TableHead className="w-10"></TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {receiptsByDate.map(({ date, receipts: dateReceipts, vendors, totalSpent, storeCount, hasLog }) => (
                    <TableRow
                      key={date}
                      className={`cursor-pointer hover:bg-slate-50 ${selectedDate === date ? "bg-blue-50" : ""}`}
                      onClick={() => handleSelectDate(date)}
                    >
                      <TableCell className="font-medium text-sm">{fmtDateWithDay(date)}</TableCell>
                      <TableCell className="text-xs text-muted-foreground truncate max-w-[180px]">
                        <span>{vendors.join(", ")}</span>
                        <span className="ml-1 text-muted-foreground">
                          <FileText className="h-3 w-3 inline" />{dateReceipts.length}
                        </span>
                        {storeCount > 1 && (
                          <span className="ml-1 text-muted-foreground">
                            <MapPin className="h-3 w-3 inline" />{storeCount}
                          </span>
                        )}
                      </TableCell>
                      <TableCell className="text-right text-sm">${totalSpent.toFixed(2)}</TableCell>
                      <TableCell>
                        {hasLog && <CheckCircle className="h-3.5 w-3.5 text-green-600" />}
                      </TableCell>
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            ) : (
              <div className="p-8 text-center text-muted-foreground text-sm">
                No in-store receipts found for the selected date range.
              </div>
            )}
          </CardContent>
        </Card>

        {/* Right: Segment entry + map (3 cols) */}
        <Card className="col-span-3">
          <CardHeader>
            <CardTitle className="text-sm">
              {selectedDate ? `Mileage Entry: ${fmtDateWithDay(selectedDate)}` : "Select a date"}
            </CardTitle>
          </CardHeader>
          <CardContent>
            {selectedDate && selectedDateData ? (
              <div className="space-y-4">
                {/* Merge warning */}
                {selectedDateData.hasLog && (
                  <div className="bg-amber-50 border border-amber-200 rounded p-2 text-sm text-amber-800 flex items-center gap-2">
                    <AlertTriangle className="h-4 w-4 flex-shrink-0" />
                    <span>
                      A {selectedDateData.log?.source} log already exists for this date. Saving will merge.
                    </span>
                  </div>
                )}

                {/* Receipts for this date */}
                <div>
                  <div className="text-xs font-medium mb-1">Receipts ({selectedDateData.receipts.length})</div>
                  <div className="space-y-1">
                    {selectedDateData.receipts.map((r) => {
                      const matchedLoc = findMatchingLocation(r)
                      return (
                        <div key={r.id} className="flex items-center gap-2 bg-slate-50 border rounded px-2 py-1 text-xs">
                          <Link to={`/receipts/${r.id}`} className="font-medium text-blue-600 hover:underline">{r.vendor_name}</Link>
                          <span className="text-muted-foreground">${parseFloat(r.total).toFixed(2)}</span>
                          <span className="text-muted-foreground ml-auto flex items-center gap-1 truncate max-w-[200px]">
                            <MapPin className="h-3 w-3 flex-shrink-0" />
                            <span className="text-green-700">{matchedLoc?.label || r.store_label || r.store_address || "Unknown"}</span>
                          </span>
                        </div>
                      )
                    })}
                  </div>
                </div>

                {/* Raw Timeline Activity (from Google Timeline uploads) */}
                {timelineSegments && timelineSegments.length > 0 && (() => {
                  const tlLabelsLocal = labelTimelineSegments(timelineSegments)
                  return (
                    <div>
                      <div className="text-xs font-medium mb-1">
                        Raw Timeline Activity ({timelineSegments.length} segments)
                        <span className="font-normal text-muted-foreground ml-1">— unprocessed Google data, may have gaps</span>
                      </div>
                      <div className="space-y-0.5 max-h-[200px] overflow-y-auto border rounded p-1.5 bg-white">
                        {timelineSegments.map((seg: TravelSegment) => {
                          const startTime = fmtTime(seg.start_time)
                          const endTime = fmtTime(seg.end_time)
                          const timeRange = startTime && endTime ? `${startTime}\u2013${endTime}` : startTime || endTime || ""
                          const classColor = seg.classification === "business" ? "text-green-700" : seg.classification === "personal" ? "text-blue-700" : "text-gray-500"
                          if (seg.segment_type === "drive") {
                            const fromLabel = tlLabelsLocal.get(seg.id) || seg.from_location || "?"
                            const toLabel = tlLabelsLocal.get(seg.id + "_to") || seg.to_location || "?"
                            return (
                              <div
                                key={seg.id}
                                className={`flex items-center gap-2 text-xs px-1.5 py-0.5 cursor-pointer transition-colors ${hoveredSegmentId === seg.id ? "bg-amber-100" : "hover:bg-slate-50"}`}
                                onMouseEnter={() => setHoveredSegmentId(seg.id)}
                                onMouseLeave={() => setHoveredSegmentId(null)}
                              >
                                <span className="text-muted-foreground w-[90px] flex-shrink-0 font-mono">{timeRange}</span>
                                <Car className="h-3 w-3 text-muted-foreground flex-shrink-0" />
                                <span className="truncate">
                                  {fromLabel} {"\u2192"} {toLabel}
                                </span>
                                {seg.distance_meters != null && (
                                  <span className="text-muted-foreground ml-auto flex-shrink-0">{(seg.distance_meters / 1000).toFixed(1)} km</span>
                                )}
                                <span className={`flex-shrink-0 ${classColor}`}>{seg.classification}</span>
                              </div>
                            )
                          }
                          const visitLabel = tlLabelsLocal.get(seg.id) || seg.visit_location_label || seg.from_location || "Unknown"
                          return (
                            <div
                              key={seg.id}
                              className={`flex items-center gap-2 text-xs px-1.5 py-0.5 cursor-pointer transition-colors ${hoveredSegmentId === seg.id ? "bg-amber-100" : "bg-slate-50 hover:bg-slate-100"}`}
                              onMouseEnter={() => setHoveredSegmentId(seg.id)}
                              onMouseLeave={() => setHoveredSegmentId(null)}
                            >
                              <span className="text-muted-foreground w-[90px] flex-shrink-0 font-mono">{timeRange}</span>
                              <MapPin className="h-3 w-3 text-muted-foreground flex-shrink-0" />
                              <span className="truncate">
                                {visitLabel}
                                {seg.visit_duration_minutes != null && (
                                  <span className="text-muted-foreground ml-1">({seg.visit_duration_minutes} min)</span>
                                )}
                              </span>
                              <span className={`ml-auto flex-shrink-0 ${classColor}`}>{seg.classification}</span>
                            </div>
                          )
                        })}
                      </div>
                    </div>
                  )
                })()}

                {/* Drive Segments */}
                <div>
                  <div className="flex items-center justify-between mb-2">
                    <div className="flex items-center gap-2">
                      <label className="text-xs font-medium">Drive Segments</label>
                      {segments.some((s) => s.source === "timeline") && (
                        <span className="text-[10px] bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">
                          auto-generated from timeline + receipts
                        </span>
                      )}
                    </div>
                    <Button variant="outline" size="sm" className="h-6 text-xs" onClick={addSegment}>
                      <Plus className="h-3 w-3 mr-1" /> Add Segment
                    </Button>
                  </div>
                  <div className="space-y-2">
                    {segments.map((seg, i) => (
                      <div key={i} className="border rounded p-2 bg-slate-50 space-y-2">
                        <div className="flex gap-2 items-center">
                          {seg.source !== "manual" && (
                            <span className={`text-[9px] px-1 py-0.5 rounded flex-shrink-0 ${seg.source === "timeline" ? "bg-blue-50 text-blue-600" : "bg-green-50 text-green-600"}`}>
                              {seg.source}
                            </span>
                          )}
                          <LocationSearch
                            locations={locationOptions}
                            value={seg.from_id}
                            onValueChange={(v) => updateSegment(i, "from_id", v)}
                            placeholder="From..."
                            className="flex-1"
                            triggerClassName="h-7"
                            onAddNew={() => {
                              setNewLocTarget({ segIndex: i, field: "from_id" })
                              setNewLocLabel(""); setNewLocAddress(""); setNewLocType("personal")
                            }}
                          />
                          <span className="text-xs text-muted-foreground">{"\u2192"}</span>
                          <LocationSearch
                            locations={locationOptions}
                            value={seg.to_id}
                            onValueChange={(v) => updateSegment(i, "to_id", v)}
                            placeholder="To..."
                            className="flex-1"
                            triggerClassName="h-7"
                            onAddNew={() => {
                              setNewLocTarget({ segIndex: i, field: "to_id" })
                              setNewLocLabel(""); setNewLocAddress(""); setNewLocType("personal")
                            }}
                          />
                        </div>
                        <div className="flex gap-2 items-center flex-wrap">
                          {!seg.isDetour && (
                            <div className="flex items-center gap-1">
                              <input
                                type="number"
                                step="0.1"
                                min="0"
                                className="w-20 text-xs border rounded px-2 py-1 h-7"
                                placeholder="km"
                                value={seg.distance_km}
                                onChange={(e) => updateSegment(i, "distance_km", e.target.value)}
                              />
                              <span className="text-xs text-muted-foreground">km</span>
                              {seg.computing && (
                                <RotateCw className="h-3 w-3 text-muted-foreground animate-spin" />
                              )}
                              {seg.routeError && (
                                <span className="text-xs text-red-600 flex items-center gap-1" title={seg.routeError}>
                                  <AlertTriangle className="h-3 w-3" />
                                  Route failed
                                </span>
                              )}
                              {seg.from_id && seg.to_id && !seg.computing && (
                                <Button
                                  variant="ghost"
                                  size="sm"
                                  className="h-6 px-1"
                                  title="Recompute distance"
                                  onClick={() => {
                                    setSegments((prev) =>
                                      prev.map((s, j) =>
                                        j === i ? { ...s, computed_km: "", distance_km: "", routeCoords: [] } : s
                                      )
                                    )
                                  }}
                                >
                                  <RotateCw className="h-3 w-3" />
                                </Button>
                              )}
                            </div>
                          )}
                          {seg.isDetour ? (
                            <span className="text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded font-medium">
                              detour: {seg.distance_km ? `${seg.distance_km} km` : "computing..."}
                            </span>
                          ) : (
                            <Select value={seg.classification} onValueChange={(v) => updateSegment(i, "classification", v)}>
                              <SelectTrigger className="h-6 w-[85px] text-[11px] px-2">
                                <SelectValue />
                              </SelectTrigger>
                              <SelectContent>
                                <SelectItem value="business" className="text-xs">Business</SelectItem>
                                <SelectItem value="personal" className="text-xs">Personal</SelectItem>
                              </SelectContent>
                            </Select>
                          )}
                          <Button
                            variant={seg.isDetour ? "default" : "outline"}
                            size="sm"
                            className={`h-6 text-[10px] px-2 ${seg.isDetour ? "bg-amber-600 hover:bg-amber-700" : ""}`}
                            onClick={() => toggleDetour(i)}
                            title={seg.isDetour ? "Switch to simple segment" : "Calculate business detour from this baseline trip"}
                          >
                            {seg.isDetour ? "Detour ON" : "Detour"}
                          </Button>
                          {segments.length > 1 && (
                            <Button
                              variant="ghost"
                              size="sm"
                              className="h-6 px-1 text-red-500"
                              onClick={() => removeSegment(i)}
                            >
                              <Trash2 className="h-3 w-3" />
                            </Button>
                          )}
                        </div>

                        {/* Detour mode: business stops + calculation breakdown */}
                        {seg.isDetour && (
                          <div className="border-t pt-2 space-y-2">
                            <div className="text-[10px] text-muted-foreground">
                              Direct: {locationOptions.find((l) => l.id === seg.from_id)?.label || "?"} {"\u2192"} {locationOptions.find((l) => l.id === seg.to_id)?.label || "?"} = {
                                seg.computingDirect ? <RotateCw className="h-3 w-3 inline animate-spin" /> :
                                seg.directKm != null ? `${seg.directKm.toFixed(1)} km` : "—"
                              }
                            </div>
                            <div className="text-[10px] font-medium">Business stops (waypoints):</div>
                            <div className="space-y-1">
                              {seg.detourStopIds.map((stopId, si) => {
                                const loc = locationOptions.find((l) => l.id === stopId)
                                return (
                                  <div key={si} className="flex items-center gap-1 text-[11px]">
                                    <span className="w-4 text-center text-muted-foreground">{si + 1}.</span>
                                    <MapPin className="h-3 w-3 text-green-600 flex-shrink-0" />
                                    <span className="truncate">{loc?.label || "Unknown"}</span>
                                    <div className="flex items-center gap-0.5 ml-auto">
                                      <Button
                                        variant="ghost"
                                        size="sm"
                                        className="h-5 w-5 p-0 text-muted-foreground"
                                        disabled={si === 0}
                                        onClick={() => moveDetourStop(i, si, "up")}
                                      >
                                        <ArrowUp className="h-2.5 w-2.5" />
                                      </Button>
                                      <Button
                                        variant="ghost"
                                        size="sm"
                                        className="h-5 w-5 p-0 text-muted-foreground"
                                        disabled={si === seg.detourStopIds.length - 1}
                                        onClick={() => moveDetourStop(i, si, "down")}
                                      >
                                        <ArrowDown className="h-2.5 w-2.5" />
                                      </Button>
                                      <Button
                                        variant="ghost"
                                        size="sm"
                                        className="h-5 px-1 text-red-400"
                                        onClick={() => removeDetourStop(i, si)}
                                      >
                                        <Trash2 className="h-2.5 w-2.5" />
                                      </Button>
                                    </div>
                                  </div>
                                )
                              })}
                              <LocationSearch
                                locations={locationOptions.filter((l) => receiptStoreLocationIds.has(l.id) && !seg.detourStopIds.includes(l.id) && l.id !== seg.from_id && l.id !== seg.to_id)}
                                value=""
                                onValueChange={(v) => addDetourStop(i, v)}
                                placeholder="Add receipt stop..."
                                className="w-full"
                                triggerClassName="h-6 text-[11px]"
                              />
                              {!addingCustomStop.has(i) ? (
                                <button
                                  className="text-[10px] text-blue-600 hover:underline"
                                  onClick={() => setAddingCustomStop((prev) => new Set(prev).add(i))}
                                >
                                  + Add from all locations
                                </button>
                              ) : (
                                <LocationSearch
                                  locations={locationOptions.filter((l) => !seg.detourStopIds.includes(l.id) && l.id !== seg.from_id && l.id !== seg.to_id)}
                                  value=""
                                  onValueChange={(v) => {
                                    addDetourStop(i, v)
                                    setAddingCustomStop((prev) => { const n = new Set(prev); n.delete(i); return n })
                                  }}
                                  placeholder="Search all locations..."
                                  className="w-full"
                                  triggerClassName="h-6 text-[11px]"
                                />
                              )}
                            </div>
                            {seg.detourStopIds.length > 0 && (
                              <div className="text-[10px] text-muted-foreground">
                                {seg.timelineTotalKm != null ? "Actual driven (GPS): " : "With stops: "}
                                {
                                  seg.computingWithStops ? <RotateCw className="h-3 w-3 inline animate-spin" /> :
                                  seg.withStopsKm != null ? `${seg.withStopsKm.toFixed(1)} km` : "—"
                                }
                                {seg.timelineTotalKm != null && (
                                  <span className="ml-1 text-blue-600">(from timeline)</span>
                                )}
                              </div>
                            )}
                            {seg.directKm != null && seg.withStopsKm != null && (
                              <div className="bg-amber-50 border border-amber-200 rounded px-2 py-1 text-xs">
                                <span className="font-medium">Business detour: </span>
                                <span className="font-bold text-amber-800">
                                  {Math.max(0, seg.withStopsKm - seg.directKm).toFixed(1)} km
                                </span>
                                <span className="text-muted-foreground ml-2">
                                  ({seg.withStopsKm.toFixed(1)} − {seg.directKm.toFixed(1)})
                                </span>
                              </div>
                            )}
                          </div>
                        )}

                        {seg.from_id && seg.to_id && !seg.isDetour && (
                          <div className="text-[10px] text-muted-foreground leading-tight">
                            {locationOptions.find((l) => l.id === seg.from_id)?.address}
                            {" \u2192 "}
                            {locationOptions.find((l) => l.id === seg.to_id)?.address}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>

                {/* Inline Add New Location */}
                {newLocTarget && (
                  <div className="border rounded p-3 bg-blue-50 space-y-2">
                    <div className="text-xs font-medium">Add New Location (for segment {newLocTarget.segIndex + 1} {newLocTarget.field === "from_id" ? "From" : "To"})</div>
                    <div className="grid grid-cols-2 gap-2">
                      <input
                        className="text-xs border rounded px-2 py-1 h-7"
                        placeholder="Label (e.g. Friend's House)"
                        value={newLocLabel}
                        onChange={(e) => setNewLocLabel(e.target.value)}
                      />
                      <input
                        className="text-xs border rounded px-2 py-1 h-7"
                        placeholder="Address (e.g. 123 Main St, Toronto)"
                        value={newLocAddress}
                        onChange={(e) => setNewLocAddress(e.target.value)}
                      />
                    </div>
                    <div className="flex items-center gap-2">
                      <Select value={newLocType} onValueChange={setNewLocType}>
                        <SelectTrigger className="h-7 w-28 text-xs">
                          <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="personal" className="text-xs">Personal</SelectItem>
                          <SelectItem value="business" className="text-xs">Business</SelectItem>
                        </SelectContent>
                      </Select>
                      <Button
                        size="sm"
                        className="h-7 text-xs"
                        disabled={!newLocLabel || !newLocAddress || createTravelLocation.isPending}
                        onClick={() => {
                          createTravelLocation.mutate(
                            { label: newLocLabel, address: newLocAddress, location_type: newLocType },
                            {
                              onSuccess: (newLoc) => {
                                updateSegment(newLocTarget.segIndex, newLocTarget.field, newLoc.id)
                                setNewLocTarget(null)
                              },
                            }
                          )
                        }}
                      >
                        {createTravelLocation.isPending ? "Creating..." : "Create & Select"}
                      </Button>
                      <Button variant="ghost" size="sm" className="h-7 text-xs" onClick={() => setNewLocTarget(null)}>
                        Cancel
                      </Button>
                    </div>
                  </div>
                )}

                {/* Map */}
                <RouteMap
                  segments={segments}
                  locations={locationOptions}
                  receiptLocations={selectedDateData.receipts}
                  timelineSegments={timelineSegments}
                  onTimelineDriveClick={handleTimelineDriveClick}
                  hoveredSegmentId={hoveredSegmentId}
                  onHoverSegment={setHoveredSegmentId}
                />

                {/* Purpose */}
                <div>
                  <label className="text-xs font-medium">Purpose</label>
                  <input
                    className="w-full text-sm border rounded px-2 py-1 mt-1"
                    value={purpose}
                    onChange={(e) => setPurpose(e.target.value)}
                    placeholder="e.g. Deliver merchandise to BSC"
                  />
                </div>

                {/* Notes */}
                <div>
                  <label className="text-xs font-medium">Notes</label>
                  <textarea
                    className="w-full text-sm border rounded px-2 py-1 mt-1"
                    rows={2}
                    value={notes}
                    onChange={(e) => setNotes(e.target.value)}
                    placeholder="Additional notes..."
                  />
                </div>

                {/* Save */}
                <div className="flex justify-end">
                  <Button disabled={!canSave || createReceiptTripLog.isPending} onClick={handleSave}>
                    <Save className="h-4 w-4 mr-1" />
                    {createReceiptTripLog.isPending
                      ? "Saving..."
                      : selectedDateData.hasLog
                        ? "Merge into Log"
                        : "Save to Log"}
                  </Button>
                </div>
              </div>
            ) : (
              <div className="text-center py-8 text-muted-foreground text-sm">
                Click a date on the left to create a mileage log entry.
              </div>
            )}
          </CardContent>
        </Card>
      </div>
    </div>
  )
}
